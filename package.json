{
  "name": "runner-lens",
  "version": "1.0.0",
  "private": true,
  "description": "Zero-config observability for GitHub Actions runners",
  "scripts": {
    "build": "node scripts/bundle.js",
    "typecheck": "node ./node_modules/typescript/bin/tsc --noEmit",
    "test": "node ./node_modules/jest/bin/jest.js --coverage",
    "prepare": "npm run build"
  },
  "dependencies": {
    "@actions/artifact": "^6.2.0",
    "@actions/core": "^1.11.1"
  },
  "devDependencies": {
    "@types/jest": "^29.5.14",
    "@types/node": "^25.3.3",
    "esbuild": "^0.27.3",
    "jest": "^29.7.0",
    "ts-jest": "^29.4.6",
    "typescript": "^5.9.3"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/runnerlens/runner-lens"
  },
  "engines": {
    "node": ">=24"
  }
}
