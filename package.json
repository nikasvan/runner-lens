{
  "name": "runner-lens",
  "version": "1.0.0",
  "private": true,
  "description": "Zero-config observability for GitHub Actions runners",
  "scripts": {
    "build": "npm run bundle:main && npm run bundle:post",
    "bundle:main": "esbuild src/main.ts --bundle --platform=node --target=node24 --outfile=dist/main/index.js --minify --sourcemap",
    "bundle:post": "esbuild src/post.ts --bundle --platform=node --target=node24 --outfile=dist/post/index.js --minify --sourcemap",
    "typecheck": "tsc --noEmit",
    "test": "jest --coverage",
    "prepare": "npm run build"
  },
  "dependencies": {
    "@actions/artifact": "^6.1.0",
    "@actions/core": "^1.11.1",
    "@actions/exec": "^1.1.1"
  },
  "devDependencies": {
    "@types/jest": "^29.5.14",
    "@types/node": "^22.13.0",
    "esbuild": "^0.25.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.2.0",
    "typescript": "^5.7.0"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/runnerlens/runner-lens"
  },
  "engines": {
    "node": ">=20"
  }
}
